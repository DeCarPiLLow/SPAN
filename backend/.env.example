# ─── Spotify OAuth ────────────────────────────────────────────────
# Create an app at https://developer.spotify.com/dashboard
# Set redirect URI in Spotify dashboard to: http://localhost:5173/callback
SPOTIFY_CLIENT_ID=your_spotify_client_id_here
SPOTIFY_REDIRECT_URI=http://localhost:5173/callback

# ─── Security ─────────────────────────────────────────────────────
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
TOKEN_ENCRYPTION_KEY=your_fernet_key_here

# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=your_jwt_secret_here

# ─── Database ─────────────────────────────────────────────────────
POSTGRES_PASSWORD=spotifypass
DATABASE_URL=postgresql://spotifyuser:spotifypass@postgres:5432/spotify_analyzer

# ─── Redis ────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ─── App ──────────────────────────────────────────────────────────
FLASK_ENV=development
FRONTEND_URL=http://localhost:5173
